# ──────────────────────────────────────────────────────────────
# DevBoard environment variables
# Copy this file to `.env` and adjust values. Never commit `.env`.
# ──────────────────────────────────────────────────────────────

# --- Database ---
# Used by Prisma and the Postgres container (docker-compose).
POSTGRES_USER=devboard
POSTGRES_PASSWORD=devboard
POSTGRES_DB=devboard
POSTGRES_PORT=5432

# Full connection string used by Prisma.
# When running the server INSIDE docker-compose, host is "postgres".
# When running the server on your host machine, host is "localhost".
DATABASE_URL=postgresql://devboard:devboard@localhost:5432/devboard?schema=public

# --- Server ---
NODE_ENV=development
SERVER_PORT=4000
# Comma-separated list of allowed origins for CORS (the client URL).
CLIENT_ORIGIN=http://localhost:5173

# --- Auth / JWT ---
# Use long random strings in real environments (e.g. `openssl rand -base64 48`).
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
# Set to "true" only when serving over HTTPS (marks cookies Secure).
COOKIE_SECURE=false

# --- Client (Vite, must be prefixed with VITE_) ---
VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000
