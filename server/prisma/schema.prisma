// DevBoard data model.
// Ordering uses fractional Float `position` so reordering touches one row.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BoardRole {
  OWNER
  EDITOR
  VIEWER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum ActivityType {
  BOARD_CREATED
  BOARD_UPDATED
  COLUMN_CREATED
  COLUMN_UPDATED
  COLUMN_DELETED
  CARD_CREATED
  CARD_UPDATED
  CARD_MOVED
  CARD_DELETED
  MEMBER_INVITED
  MEMBER_JOINED
  MEMBER_ROLE_CHANGED
  MEMBER_REMOVED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedBoards   Board[]        @relation("BoardOwner")
  memberships   BoardMember[]
  assignedCards Card[]         @relation("CardAssignee")
  refreshTokens RefreshToken[]
  activities    Activity[]

  @@map("users")
}

// Hashed refresh tokens for rotation + reuse detection.
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Board {
  id        String   @id @default(uuid())
  title     String
  ownerId   String
  owner     User     @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  columns    Column[]
  members    BoardMember[]
  labels     Label[]
  invites    Invite[]
  activities Activity[]

  @@index([ownerId])
  @@map("boards")
}

// Access-control source of truth. One row per (board, user).
model BoardMember {
  id        String    @id @default(uuid())
  boardId   String
  board     Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      BoardRole @default(EDITOR)
  createdAt DateTime  @default(now())

  @@unique([boardId, userId])
  @@index([userId])
  @@map("board_members")
}

model Column {
  id       String @id @default(uuid())
  boardId  String
  board    Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  title    String
  position Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cards Card[]

  @@index([boardId])
  @@map("columns")
}

model Card {
  id          String    @id @default(uuid())
  columnId    String
  column      Column    @relation(fields: [columnId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?
  position    Float
  assigneeId  String?
  assignee    User?     @relation("CardAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  labels CardLabel[]

  @@index([columnId])
  @@index([assigneeId])
  @@map("cards")
}

model Label {
  id      String @id @default(uuid())
  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name    String
  color   String

  cards CardLabel[]

  @@index([boardId])
  @@map("labels")
}

// Many-to-many join between cards and labels.
model CardLabel {
  cardId  String
  card    Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  labelId String
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@index([labelId])
  @@map("card_labels")
}

model Invite {
  id        String       @id @default(uuid())
  boardId   String
  board     Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  email     String
  role      BoardRole    @default(EDITOR)
  token     String       @unique
  status    InviteStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime     @default(now())

  @@index([boardId])
  @@index([email])
  @@map("invites")
}

model Activity {
  id        String       @id @default(uuid())
  boardId   String
  board     Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      ActivityType
  metadata  Json         @default("{}")
  createdAt DateTime     @default(now())

  @@index([boardId])
  @@map("activities")
}
